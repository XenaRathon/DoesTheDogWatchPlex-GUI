# DoesTheDogWatchPlex Configuration
# Copy this file to config.py and fill in your details.

# --- Plex Settings ---
# Your Plex server URL (include port if non-standard)
PLEX_URL = "http://localhost:32400"

# Your Plex authentication token
# Find it: open Plex web, inspect any request, look for X-Plex-Token parameter
# Or see: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_TOKEN = "your-plex-token-here"

# Which kinds of library to process. Any of: "movies", "tv_shows".
# Movies get one warning block on the movie summary; TV shows get warnings at the
# levels listed in TV_WARNING_LEVELS below.
PLEX_LIBRARY_TYPES = ["movies"]

# Library names to process (case-sensitive, as they appear in Plex).
# Only libraries whose type is in PLEX_LIBRARY_TYPES are touched.
# Set to None to process ALL libraries matching PLEX_LIBRARY_TYPES.
PLEX_LIBRARIES = ["Movies"]

# For TV shows, which levels to write warnings to. Any of:
#   "series"  → the show summary        (whole-series community votes)
#   "season"  → each season summary     (DTDD index1=<season>, index2=-1)
#   "episode" → each episode summary     (DTDD index1=<season>, index2=<episode>)
# Fewer levels = far fewer API calls. Episode level is the slowest (one call each).
#
# NOTE on episode accuracy: DTDD's per-episode data is community-sourced and
# imperfect. A few high-profile topics (animal deaths especially) have their
# series-wide votes attributed to early episodes, so episode 1 may show a couple
# of warnings that really apply to the series as a whole. Most episode warnings
# are accurate; this is a known DTDD data limitation, not a matching bug.
TV_WARNING_LEVELS = ["series", "season", "episode"]

# --- DoesTheDogDie Settings ---
# Get your API key: sign up at doesthedogdie.com, then visit /profile
DTDD_API_KEY = "your-dtdd-api-key-here"

# --- Behavior ---
# Separator line between original summary and content warnings
SEPARATOR = "\n\n———— Content Warnings (via DoesTheDogDie.com) ————"

# Minimum yes votes for a warning to be included (filters out low-confidence entries)
MIN_YES_VOTES = 5

# Only show warnings where "yes" votes outnumber "no" votes by this ratio
MIN_YES_RATIO = 0.7

# Show the ✅ "safe" topics (e.g., "no dogs die")? These lists tend to be huge.
# Set to True if you want them included.
SHOW_SAFE_TOPICS = False

# --- Topic Filtering ---
# Only show warnings for these specific topics (by name from DTDD).
# If set, ONLY these topics will appear. Leave as None to show all.
# Run: python plex_warnings.py --list-topics to see all available topic names.
# Example:
# INCLUDE_TOPICS = [
#     "a dog dies",
#     "a cat dies",
#     "someone is sexually assaulted",
#     "someone dies by suicide",
#     "there's flashing lights or images",
#     "someone self harms",
#     "there's excessive gore",
# ]
INCLUDE_TOPICS = None

# Exclude these specific topics (ignored if INCLUDE_TOPICS is set).
# Example:
# EXCLUDE_TOPICS = ["there is copaganda", "there are shower scenes"]
EXCLUDE_TOPICS = None

# --- Translation ---
# Translate topic names to another language before writing to Plex.
# Uses Google Translate. Set to a language code (e.g., "es", "fr", "de", "pt", "ja").
# Leave as None for English (default). Translations are cached locally.
# Full list of supported codes: https://cloud.google.com/translate/docs/languages
LANGUAGE = None

# How long to cache DTDD results locally (seconds). Default: 7 days
CACHE_TTL = 60 * 60 * 24 * 7

# Rate limit delay between DTDD API calls (seconds) — be kind to their server
API_DELAY = 1.0

# Dry run mode: if True, prints what would change without modifying Plex
DRY_RUN = False
